---
// Footer component
import { siteConfig } from '../config/site';

const { name, nav, contact, social } = siteConfig;
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-900 text-white pt-16 pb-8">
  <div class="container-rrt">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2 mb-4">
          <div class="w-10 h-10 bg-primary rounded-full flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white">
              <path d="M12 2a10 10 0 1 0 10 10"/>
              <path d="M12 12 8 8"/>
              <path d="M12 2v10"/>
            </svg>
          </div>
          <span class="font-poppins font-bold text-xl">{name}</span>
        </div>
        <p class="text-gray-400 text-sm leading-relaxed mb-6">
          Elite rhythmic gymnastics training in Texas. Building champions through discipline, artistry, and dedication.
        </p>
        <!-- Social links -->
        <div class="flex gap-4">
          <a 
            href={social.instagram} 
            target="_blank" 
            rel="noopener noreferrer"
            class="w-10 h-10 bg-white/10 rounded-full flex items-center justify-center hover:bg-primary transition-colors duration-200"
            aria-label="Instagram"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
            </svg>
          </a>
          <a 
            href={social.facebook} 
            target="_blank" 
            rel="noopener noreferrer"
            class="w-10 h-10 bg-white/10 rounded-full flex items-center justify-center hover:bg-primary transition-colors duration-200"
            aria-label="Facebook"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-poppins font-semibold text-lg mb-4">Quick Links</h4>
        <ul class="space-y-3">
          {nav.map((item) => (
            <li>
              <a href={item.href} class="text-gray-400 hover:text-primary transition-colors duration-200">
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Programs -->
      <div>
        <h4 class="font-poppins font-semibold text-lg mb-4">Programs</h4>
        <ul class="space-y-3">
          <li><a href="/programs#recreational" class="text-gray-400 hover:text-primary transition-colors duration-200">Recreational</a></li>
          <li><a href="/programs#competitive" class="text-gray-400 hover:text-primary transition-colors duration-200">Competitive Team</a></li>
          <li><a href="/programs#private" class="text-gray-400 hover:text-primary transition-colors duration-200">Private Lessons</a></li>
          <li><a href="/programs#camps" class="text-gray-400 hover:text-primary transition-colors duration-200">Camps & Clinics</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-poppins font-semibold text-lg mb-4">Contact Us</h4>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary mt-0.5 shrink-0">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <span class="text-gray-400">{contact.address}</span>
          </li>
          <li class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <a href={`tel:${contact.phone}`} class="text-gray-400 hover:text-primary transition-colors duration-200">
              {contact.phone}
            </a>
          </li>
          <li class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0">
              <rect width="20" height="16" x="2" y="4" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            <a href={`mailto:${contact.email}`} class="text-gray-400 hover:text-primary transition-colors duration-200">
              {contact.email}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-gray-800 pt-8">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-gray-500 text-sm">
          © {currentYear} {name}. All rights reserved.
        </p>
        <div class="flex gap-6 text-sm">
          <a href="/privacy" class="text-gray-500 hover:text-primary transition-colors duration-200">Privacy Policy</a>
          <a href="/terms" class="text-gray-500 hover:text-primary transition-colors duration-200">Terms of Service</a>
        </div>
      </div>
    </div>
  </div>
</footer>
