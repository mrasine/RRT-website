---
import rrtLogo from '../assets/rrt-logo.png';

const currentYear = new Date().getFullYear();

const quickLinks = [
    { href: '/about/', label: 'About Us' },
    { href: '/programs/', label: 'Programs' },
    { href: '/schedule/', label: 'Schedule' },
    { href: '/contact/', label: 'Contact' },
];

const programs = [
    { href: '/programs/', label: 'Recreational Classes' },
    { href: '/programs/', label: 'Pre-Team' },
    { href: '/programs/', label: 'Competitive Team' },
    { href: '/programs/', label: 'Xcel Program' },
    { href: '/programs/', label: 'Ballet' },
];

const socialLinks = [
    { href: 'https://instagram.com/rhythmicribbonoftexas', label: 'Instagram', icon: 'IG' },
    { href: 'https://facebook.com/RhythmicRibbon', label: 'Facebook', icon: 'FB' },
    { href: 'https://tiktok.com', label: 'TikTok', icon: 'TT' },
];
---

<footer class="footer">
    <div class="container">
        <div class="footer-cta">
            <h2>Ready to Start Your Journey?</h2>
            <p>Book a free trial class and discover the magic of rhythmic gymnastics.</p>
            <a href="/contact/" class="btn btn-primary btn-lg">Book Free Trial</a>
        </div>
        
        <div class="footer-divider"></div>
        
        <div class="footer-grid">
            <div class="footer-brand">
                <img src={rrtLogo.src} alt="Rhythmic Ribbon of Texas" class="logo-img" />
                <p class="tagline">Where Grace Meets Strength</p>
                <p class="description">Premier rhythmic gymnastics academy in McKinney, Texas. Building confident athletes through expert coaching and a supportive community.</p>
                
                <div class="social-links">
                    {socialLinks.map(link => (
                        <a href={link.href} target="_blank" rel="noopener" class="social-link" aria-label={link.label}>
                            {link.icon}
                        </a>
                    ))}
                </div>
            </div>
            
            <div class="footer-section">
                <h4>Quick Links</h4>
                <ul>
                    {quickLinks.map(link => (
                        <li><a href={link.href}>{link.label}</a></li>
                    ))}
                </ul>
            </div>
            
            <div class="footer-section">
                <h4>Programs</h4>
                <ul>
                    {programs.map(link => (
                        <li><a href={link.href}>{link.label}</a></li>
                    ))}
                </ul>
            </div>
            
            <div class="footer-section">
                <h4>Contact</h4>
                <address>
                    <p>4260 Eldorado Parkway<br>McKinney, TX 75070</p>
                    <p><a href="tel:7186892469">(718) 689-2469</a></p>
                    <p><a href="mailto:info@rhythmicribbon.com">info@rhythmicribbon.com</a></p>
                </address>
            </div>
        </div>
        
        <div class="footer-bottom">
            <p>&copy; {currentYear} Rhythmic Ribbon of Texas. All rights reserved.</p>
            <p class="legal-links">
                <a href="/privacy/">Privacy Policy</a>
                <a href="/terms/">Terms of Service</a>
            </p>
        </div>
    </div>
</footer>

<style>
    .footer {
        background: #0D0D0D;
        color: #F5F0E6;
        padding: 0 0 2rem;
        border-top: 1px solid rgba(212, 175, 55, 0.1);
    }
    
    .footer-cta {
        text-align: center;
        padding: 4rem 0;
        background: linear-gradient(180deg, #1A1A1A 0%, #0D0D0D 100%);
        border-radius: 0 0 24px 24px;
        margin-bottom: 3rem;
    }
    
    .footer-cta h2 {
        font-size: 2rem;
        margin-bottom: 1rem;
        color: #D4AF37;
    }
    
    .footer-cta p {
        color: rgba(245, 240, 230, 0.7);
        margin-bottom: 1.5rem;
        font-size: 1.125rem;
    }
    
    .footer-divider {
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(212, 175, 55, 0.3), transparent);
        margin-bottom: 3rem;
    }
    
    .footer-grid {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: 3rem;
        margin-bottom: 3rem;
    }
    
    .logo-img {
        height: 60px;
        width: auto;
        object-fit: contain;
        margin-bottom: 1rem;
    }
    
    .tagline {
        color: #D4AF37;
        font-style: italic;
        margin-bottom: 0.75rem;
        font-size: 1.125rem;
    }
    
    .description {
        color: rgba(245, 240, 230, 0.7);
        font-size: 0.9375rem;
        line-height: 1.6;
        margin-bottom: 1.5rem;
    }
    
    .social-links {
        display: flex;
        gap: 0.75rem;
    }
    
    .social-link {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: #1A1A1A;
        border: 1px solid rgba(212, 175, 55, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Poppins', sans-serif;
        font-weight: 700;
        font-size: 0.75rem;
        color: #F5F0E6;
        transition: all 0.3s ease;
    }
    
    .social-link:hover {
        background: #D4AF37;
        border-color: #D4AF37;
        color: #0D0D0D;
        transform: translateY(-3px);
        box-shadow: 0 4px 15px rgba(212, 175, 55, 0.3);
    }
    
    .footer-section h4 {
        font-size: 1.125rem;
        margin-bottom: 1.25rem;
        color: #D4AF37;
        font-weight: 600;
    }
    
    .footer-section ul {
        list-style: none;
    }
    
    .footer-section li {
        margin-bottom: 0.75rem;
    }
    
    .footer-section a {
        color: rgba(245, 240, 230, 0.7);
        transition: all 0.3s ease;
        display: inline-block;
    }
    
    .footer-section a:hover {
        color: #D4AF37;
        transform: translateX(4px);
    }
    
    .footer-section address {
        font-style: normal;
        line-height: 1.8;
        color: rgba(245, 240, 230, 0.7);
    }
    
    .footer-section address a {
        color: #D4AF37;
    }
    
    .footer-bottom {
        border-top: 1px solid rgba(245, 240, 230, 0.1);
        padding-top: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        color: rgba(245, 240, 230, 0.5);
        font-size: 0.875rem;
    }
    
    .legal-links {
        display: flex;
        gap: 1.5rem;
    }
    
    .legal-links a {
        color: rgba(245, 240, 230, 0.5);
    }
    
    .legal-links a:hover {
        color: #D4AF37;
    }
    
    @media (max-width: 1024px) {
        .footer-grid {
            grid-template-columns: 1fr 1fr;
        }
        
        .footer-brand {
            grid-column: 1 / -1;
            text-align: center;
        }
        
        .social-links {
            justify-content: center;
        }
    }
    
    @media (max-width: 640px) {
        .footer-grid {
            grid-template-columns: 1fr;
            gap: 2rem;
            text-align: center;
        }
        
        .footer-bottom {
            flex-direction: column;
            text-align: center;
        }
        
        .legal-links {
            justify-content: center;
        }
    }
</style>
