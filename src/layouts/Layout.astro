---
interface Props {
    title: string;
    description: string;
    keywords?: string;
    ogImage?: string;
}

const { 
    title, 
    description, 
    keywords = "rhythmic gymnastics, ribbon, Texas, gymnastics classes, kids gymnastics, dance, performance",
    ogImage = "/og-image.jpg"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Rhythmic Ribbon of Texas" />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700&family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <slot name="head" />
</head>
<body>
    <slot />
</body>
</html>

<style is:global>
    :root {
        /* RRT Brand Colors - Gold on Black */
        --primary: #D4AF37;
        --primary-dark: #C9A227;
        --secondary: #C9A227;
        --secondary-dark: #B8961F;
        --accent: #E8C84D;
        --accent-glow: rgba(212, 175, 55, 0.3);
        --dark: #0D0D0D;
        --dark-secondary: #1A1A1A;
        --dark-tertiary: #2A2A2A;
        --light: #1A1A1A;
        --white: #F5F0E6;
        --cream: #F5F0E6;
        --gray: #AAAAAA;
        --gray-dark: #666666;
        --shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
        --shadow-lg: 0 10px 40px rgba(0, 0, 0, 0.6);
        --shadow-gold: 0 0 30px rgba(212, 175, 55, 0.2);
    }
    
    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }
    
    html {
        scroll-behavior: smooth;
    }
    
    body {
        font-family: 'Open Sans', system-ui, sans-serif;
        line-height: 1.6;
        color: var(--cream);
        background: var(--dark);
    }
    
    h1, h2, h3, h4, h5, h6 {
        font-family: 'Poppins', sans-serif;
        font-weight: 700;
        line-height: 1.2;
    }
    
    a {
        text-decoration: none;
        color: var(--primary);
        transition: color 0.3s ease;
    }
    
    a:hover {
        color: var(--accent);
    }
    
    img {
        max-width: 100%;
        height: auto;
    }
    
    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
    }
    
    /* Button Styles - Gold on Black Theme */
    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 1rem 2rem;
        border-radius: 8px;
        font-family: 'Poppins', sans-serif;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
        text-align: center;
    }
    
    /* Primary: Gold background, black text */
    .btn-primary {
        background: var(--primary);
        color: var(--dark) !important;
        box-shadow: 0 4px 15px rgba(212, 175, 55, 0.3);
    }
    
    .btn-primary:hover {
        background: var(--accent);
        color: var(--dark) !important;
        transform: translateY(-2px);
        box-shadow: 0 6px 25px rgba(232, 200, 77, 0.4);
    }
    
    /* Secondary: Dark background, gold text */
    .btn-secondary {
        background: var(--dark-secondary);
        color: var(--primary) !important;
        border: 2px solid var(--primary);
    }
    
    .btn-secondary:hover {
        background: var(--primary);
        color: var(--dark) !important;
        transform: translateY(-2px);
        box-shadow: var(--shadow-gold);
    }
    
    /* Outline: Transparent bg, gold border, gold text */
    .btn-outline {
        background: transparent;
        color: var(--primary) !important;
        border: 2px solid var(--primary);
    }
    
    .btn-outline:hover {
        background: var(--primary);
        color: var(--dark) !important;
        transform: translateY(-2px);
        box-shadow: var(--shadow-gold);
    }
    
    .btn-lg {
        padding: 1.125rem 2.5rem;
        font-size: 1.125rem;
    }
    
    /* Section Styles */
    .section {
        padding: 6rem 0;
    }
    
    .section-alt {
        background: var(--dark-secondary);
    }
    
    /* Section Title - Gold, centered */
    .section-title {
        font-size: clamp(2rem, 5vw, 3rem);
        text-align: center;
        margin-bottom: 1rem;
        color: var(--primary);
    }
    
    /* Section Subtitle - Light gray, centered */
    .section-subtitle {
        text-align: center;
        color: var(--gray);
        font-size: 1.125rem;
        max-width: 600px;
        margin: 0 auto 3rem;
    }
    
    /* Gold accent line */
    .section-title::after {
        content: '';
        display: block;
        width: 60px;
        height: 3px;
        background: linear-gradient(90deg, var(--primary), var(--accent));
        margin: 1rem auto 0;
        border-radius: 2px;
    }
    
    /* Highlight text */
    .highlight {
        color: var(--accent);
    }
    
    /* Page Header - Common for all pages */
    .page-header {
        background: var(--dark);
        color: var(--cream);
        padding: 140px 0 4rem;
        text-align: center;
        position: relative;
    }
    
    .page-header::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 100px;
        height: 3px;
        background: linear-gradient(90deg, transparent, var(--primary), transparent);
    }
    
    .page-header h1 {
        font-size: clamp(2.5rem, 5vw, 3.5rem);
        margin-bottom: 1rem;
        color: var(--primary);
    }
    
    .page-header .subtitle {
        font-size: 1.25rem;
        color: var(--gray);
        max-width: 600px;
        margin: 0 auto;
    }
    
    .section-tag {
        display: inline-block;
        color: var(--primary);
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.875rem;
        letter-spacing: 0.1em;
        margin-bottom: 1rem;
    }
    
    /* Card styles - Dark backgrounds */
    .card {
        background: var(--dark-secondary);
        border-radius: 16px;
        padding: 2rem;
        border: 1px solid var(--dark-tertiary);
        transition: all 0.3s ease;
    }
    
    .card:hover {
        border-color: var(--primary);
        box-shadow: var(--shadow-gold);
        transform: translateY(-4px);
    }
    
    /* Form styles */
    input,
    select,
    textarea {
        width: 100%;
        padding: 0.875rem 1rem;
        background: var(--dark-tertiary);
        border: 2px solid var(--dark-tertiary);
        border-radius: 8px;
        font-family: inherit;
        font-size: 1rem;
        color: var(--cream);
        transition: all 0.3s ease;
    }
    
    input:focus,
    select:focus,
    textarea:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.1);
    }
    
    input::placeholder,
    textarea::placeholder {
        color: var(--gray-dark);
    }
    
    label {
        display: block;
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: var(--cream);
        font-size: 0.9375rem;
    }
    
    @media (max-width: 768px) {
        .section {
            padding: 4rem 0;
        }
        
        .btn-lg {
            padding: 1rem 2rem;
            font-size: 1rem;
        }
    }
</style>