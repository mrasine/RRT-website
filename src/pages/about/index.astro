---
import Layout from '../layouts/Layout.astro';

const title = "About Us | Rhythmic Ribbon of Texas";
const description = "Learn about Rhythmic Ribbon of Texas - our mission, coaches, and passion for rhythmic gymnastics.";
---

<Layout title={title} description={description}>
    <main class="page-content">
        <div class="container">
            <h1>About Rhythmic Ribbon of Texas</h1>
            <p>We are dedicated to bringing the art and sport of rhythmic gymnastics to Texas.</p>
        </div>
    </main>
</Layout>

<style>
    .page-content {
        padding: 4rem 2rem;
        max-width: 800px;
        margin: 0 auto;
    }
    h1 {
        font-size: 2.5rem;
        margin-bottom: 1rem;
    }
</style>
