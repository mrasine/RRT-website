---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "Book Free Trial | Rhythmic Ribbon of Texas";
const description = "Book your free trial class in McKinney or Frisco. USAG certified coaches. Ages 5+. Schedule online today.";

const faqs = [
    { q: "What should my child wear to class?", a: "Leotard or fitted athletic wear, hair in neat bun/ponytail, bare feet or gymnastics shoes, NO jewelry, NO loose clothing." },
    { q: "How do I know which program is right for my child?", a: "We offer free assessments! Book a trial class where our coaches can evaluate your child's skills and recommend the best program." },
    { q: "What is your makeup policy?", a: "We understand schedules change. We offer one makeup class per month for absences with advance notice." },
    { q: "Do you offer private lessons?", a: "Yes! Private lessons are available for one-on-one coaching. Contact us for availability." },
    { q: "Can parents watch classes?", a: "Absolutely! We have a comfortable viewing area. We also offer parent observation weeks throughout the year." }
];
---

<Layout title={title} description={description}>
    <Header />
    
    <main>
        <section class="page-header">
            <div class="container">
                <span class="section-tag">Book Online</span>
                <h1>Free Trial<br><span class="highlight">Class</span></h1>
                <p class="subtitle">Select a time below to book your free trial. No credit card required.</p>
            </div>
        </section>
        
        <section class="section booking-section">
            <div class="container">
                <div class="calendly-container">
                    <div class="calendly-placeholder">
                        <h3>Book Your Free Trial</h3>
                        <p>Click below to schedule your free trial class.</p>
                        <a href="https://calendly.com/YOUR-CALENDLY-LINK" target="_blank" class="btn btn-primary btn-lg">Open Booking Calendar</a>
                        <p class="help-text">Or call us at (718) 689-2469</p>
                    </div>
                </div>
            </div>
        </section>
        
        <section class="section waiver-section">
            <div class="container">
                <div class="waiver-grid">
                    <div class="waiver-info">
                        <h2>Complete Your Waiver</h2>
                        <p>Please complete the online waiver before your first class.</p>
                        <div class="waiver-options">
                            <a href="YOUR-GOOGLE-FORM-LINK" target="_blank" class="waiver-option">Complete Online Waiver</a>
                            <a href="/waiver.pdf" download class="waiver-option">Download PDF Waiver</a>
                        </div>
                    </div>
                    <div class="contact-info">
                        <h3>Questions?</h3>
                        <div class="info-item"><strong>Phone</strong><a href="tel:7186892469">(718) 689-2469</a></div>
                        <div class="info-item"><strong>Email</strong><a href="mailto:rhythmicribbonoftexas@gmail.com">rhythmicribbonoftexas@gmail.com</a></div>
                    </div>
                </div>
            </div>
        </section>
        
        <section class="section faq-section">
            <div class="container">
                <h2 class="section-title">Frequently Asked<br><span class="highlight">Questions</span></h2>
                <div class="faq-grid">
                    {faqs.map(faq => (
                        <details class="faq-item"><summary>{faq.q}</summary><p>{faq.a}</p></details>
                    ))}
                </div>
            </div>
        </section>
    </main>
    
    <Footer />
</Layout>

<style>
    .page-header { background: linear-gradient(135deg, #0D0D0D 0%, #1A1A1A 100%); color: #F5F0E6; padding: 160px 0 4rem; text-align: center; }
    .page-header h1 { font-size: clamp(2.5rem, 5vw, 3.5rem); margin-bottom: 1rem; }
    .page-header .subtitle { font-size: 1.25rem; color: rgba(245, 240, 230, 0.8); }
    .booking-section { background: #0D0D0D; padding: 4rem 0; }
    .calendly-container { max-width: 800px; margin: 0 auto; }
    .calendly-placeholder { background: #1A1A1A; border-radius: 16px; padding: 4rem 2rem; text-align: center; border: 1px solid rgba(212, 175, 55, 0.2); }
    .calendly-placeholder h3 { color: #D4AF37; font-size: 1.5rem; margin-bottom: 1rem; }
    .calendly-placeholder p { color: #AAAAAA; margin-bottom: 2rem; }
    .help-text { margin-top: 1.5rem; font-size: 0.9rem; }
    .waiver-section { background: #1A1A1A; padding: 4rem 0; }
    .waiver-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 4rem; }
    .waiver-info h2 { color: #F5F0E6; font-size: 2rem; margin-bottom: 1rem; }
    .waiver-info > p { color: #AAAAAA; margin-bottom: 2rem; }
    .waiver-options { display: flex; gap: 1rem; flex-wrap: wrap; }
    .waiver-option { display: flex; align-items: center; gap: 0.75rem; background: #2A2A2A; padding: 1rem 1.5rem; border-radius: 8px; color: #F5F0E6; font-weight: 600; transition: all 0.3s; }
    .waiver-option:hover { background: #D4AF37; color: #0D0D0D; }
    .contact-info h3 { color: #F5F0E6; margin-bottom: 1.5rem; }
    .info-item { margin-bottom: 1.5rem; }
    .info-item strong { display: block; color: #D4AF37; margin-bottom: 0.25rem; }
    .info-item a { color: #F5F0E6; }
    .faq-section { background: #0D0D0D; }
    .faq-grid { max-width: 800px; margin: 3rem auto 0; }
    .faq-item { background: #1A1A1A; border-radius: 8px; margin-bottom: 1rem; overflow: hidden; }
    .faq-item summary { padding: 1.25rem; cursor: pointer; font-weight: 600; color: #F5F0E6; }
    .faq-item summary::after { content: '+'; float: right; color: #D4AF37; font-size: 1.5rem; }
    .faq-item[open] summary::after { content: '-'; }
    .faq-item p { padding: 0 1.25rem 1.25rem; color: #AAAAAA; line-height: 1.6; }
    @media (max-width: 768px) { .waiver-grid { grid-template-columns: 1fr; } }
</style>
