---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "Gallery | Rhythmic Ribbon of Texas";
const description = "See Rhythmic Ribbon of Texas in action. Photos from classes, competitions, and performances. Follow us @rhythmicribbonoftexas on Instagram.";

const galleryImages = [
    { alt: "Ribbon routine", category: "performances" },
    { alt: "Class training", category: "classes" },
    { alt: "Competition team", category: "competitions" },
    { alt: "Hoop routine", category: "performances" },
    { alt: "Young gymnast", category: "classes" },
    { alt: "Team photo", category: "competitions" },
    { alt: "Ball routine", category: "performances" },
    { alt: "Stretching", category: "classes" },
    { alt: "Award ceremony", category: "competitions" }
];
---

<Layout title={title} description={description}>
    <Header />
    
    <main>
        <section class="page-header">
            <div class="container">
                <span class="section-tag">Gallery</span>
                <h1>Moments of<br><span class="highlight">Grace & Strength</span></h1>
                <p class="subtitle">Follow our journey on Instagram @rhythmicribbonoftexas</p>
            </div>
        </section>
        
        <section class="section">
            <div class="container">
                <div class="gallery-filters">
                    <button class="filter-btn active">All</button>
                    <button class="filter-btn">Classes</button>
                    <button class="filter-btn">Competitions</button>
                    <button class="filter-btn">Performances</button>
                </div>
                
                <div class="gallery-grid">
                    {galleryImages.map((img, i) => (
                        <div class={`gallery-item ${img.category}`}>
                            <div class="image-placeholder">
                                <span>{img.alt}</span>
                            </div>
                            <div class="overlay">
                                <span class="category">{img.category}</span>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </section>
        
        <section class="section instagram-section">
            <div class="container">
                <div class="instagram-card">
                    <div class="instagram-content">
                        <h2>Follow Our Journey</h2>
                        <p>See daily updates, behind-the-scenes moments, and competition highlights on Instagram.</p>
                        
                        <div class="instagram-stats">
                            <div class="stat">
                                <span class="number">6,108</span>
                                <span class="label">Followers</span>
                            </div>
                            <div class="stat">
                                <span class="number">987</span>
                                <span class="label">Posts</span>
                            </div>
                        </div>
                        
                        <a href="https://instagram.com/rhythmicribbonoftexas" target="_blank" rel="noopener" class="btn btn-primary btn-lg">
                            @rhythmicribbonoftexas
                        </a>
                    </div>
                </div>
            </div>
        </section>
    </main>
    
    <Footer />
</Layout>

<style>
    .page-header {
        background: linear-gradient(135deg, var(--dark) 0%, #1a252f 100%);
        color: white;
        padding: 160px 0 4rem;
        text-align: center;
    }
    
    .page-header h1 {
        font-size: clamp(2.5rem, 5vw, 3.5rem);
        margin-bottom: 1rem;
    }
    
    .page-header .subtitle {
        font-size: 1.25rem;
        color: rgba(255,255,255,0.8);
        max-width: 600px;
        margin: 0 auto;
    }
    
    .gallery-filters {
        display: flex;
        justify-content: center;
        gap: 1rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }
    
    .filter-btn {
        padding: 0.625rem 1.5rem;
        border: 2px solid #e5e7eb;
        background: white;
        border-radius: 50px;
        font-family: 'Poppins', sans-serif;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.3s;
    }
    
    .filter-btn:hover,
    .filter-btn.active {
        background: var(--primary);
        border-color: var(--primary);
        color: white;
    }
    
    .gallery-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
    }
    
    .gallery-item {
        position: relative;
        border-radius: 16px;
        overflow: hidden;
        aspect-ratio: 1;
        cursor: pointer;
    }
    
    .image-placeholder {
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, var(--secondary) 0%, var(--primary) 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-family: 'Poppins', sans-serif;
        font-weight: 600;
        font-size: 1.125rem;
        transition: transform 0.3s;
    }
    
    .gallery-item:hover .image-placeholder {
        transform: scale(1.05);
    }
    
    .overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 1rem;
        background: linear-gradient(transparent, rgba(0,0,0,0.7));
        opacity: 0;
        transition: opacity 0.3s;
    }
    
    .gallery-item:hover .overlay {
        opacity: 1;
    }
    
    .category {
        color: white;
        font-size: 0.875rem;
        text-transform: capitalize;
        font-weight: 500;
    }
    
    .instagram-section {
        background: var(--light);
    }
    
    .instagram-card {
        background: linear-gradient(135deg, #833AB4 0%, #FD1D1D 50%, #F77737 100%);
        border-radius: 24px;
        padding: 4rem;
        text-align: center;
        color: white;
    }
    
    .instagram-content h2 {
        font-size: 2.5rem;
        margin-bottom: 1rem;
    }
    
    .instagram-content p {
        font-size: 1.25rem;
        opacity: 0.95;
        max-width: 500px;
        margin: 0 auto 2rem;
    }
    
    .instagram-stats {
        display: flex;
        justify-content: center;
        gap: 4rem;
        margin-bottom: 2rem;
    }
    
    .instagram-stats .stat {
        display: flex;
        flex-direction: column;
    }
    
    .instagram-stats .number {
        font-family: 'Poppins', sans-serif;
        font-size: 2.5rem;
        font-weight: 800;
    }
    
    .instagram-stats .label {
        font-size: 0.9375rem;
        opacity: 0.9;
    }
    
    @media (max-width: 768px) {
        .gallery-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
        }
        
        .instagram-card {
            padding: 2rem;
        }
        
        .instagram-stats {
            gap: 2rem;
        }
    }
</style>
