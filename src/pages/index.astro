---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "Rhythmic Ribbon of Texas | Premier Rhythmic Gymnastics";
const description = "Join McKinney's premier rhythmic gymnastics academy. Programs for ages 3+ from recreational to competitive. Expert coaching in a supportive environment.";
---

<Layout title={title} description={description}>
    <Header />
    
    <main>
        <!-- Hero Section -->
        <section class="hero">
            <div class="hero-content">
                <span class="hero-badge"><span class="badge-icon"></span> McKinney's Premier Academy</span>
                <h1>Where Grace<br><span class="highlight">Meets Strength</span></h1>
                <p class="hero-text">Rhythmic gymnastics for ages 3+. From first twirls to competitive excellence, we help every gymnast shine.</p>
                
                <div class="hero-actions">
                    <a href="/contact/" class="btn btn-primary btn-lg">Book Free Trial Class</a>
                    <a href="/contact/" class="btn btn-outline btn-lg">Contact Us</a>
                </div>
                
                <div class="hero-stats">
                    <div class="stat">
                        <span class="stat-number">3+</span>
                        <span class="stat-label">Years Old</span>
                    </div>
                    <div class="stat">
                        <span class="stat-number">USAG</span>
                        <span class="stat-label">Certified</span>
                    </div>
                    <div class="stat">
                        <span class="stat-number">6K+</span>
                        <span class="stat-label">Followers</span>
                    </div>
                </div>
            </div>
            
            <div class="hero-visual">
                <img src="/images/hero-competition.jpg" alt="RRT Competition Team with hoops" class="hero-image" />
            </div>
        </section>
        
        <!-- Programs Section -->
        <section class="section programs">
            <div class="container">
                <h2 class="section-title" style="color: #F5F0E6;">Programs for Every<br><span class="highlight">Gymnast</span></h2>
                <p class="section-subtitle" style="color: rgba(245, 240, 230, 0.7);">From first steps on the mat to competitive excellence, we have a program that's right for your child.</p>
                
                <div class="program-cards">
                    <a href="/contact/" class="program-card">
                        <div class="card-icon recreational"></div>
                        <h3>Recreational</h3>
                        <p>Ages 3+. Fun fundamentals, flexibility, and a love for movement.</p>
                        <span class="card-link">Book Free Trial →</span>
                    </a>
                    
                    <a href="/contact/" class="program-card">
                        <div class="card-icon preteam"></div>
                        <h3>Pre-Team</h3>
                        <p>Bridge program building skills for competitive readiness.</p>
                        <span class="card-link">Book Free Trial →</span>
                    </a>
                    
                    <a href="/contact/" class="program-card">
                        <div class="card-icon competitive"></div>
                        <h3>Competitive</h3>
                        <p>USAG Levels 3-10. Serious training for dedicated athletes.</p>
                        <span class="card-link">Book Free Trial →</span>
                    </a>
                </div>
            </div>
        </section>
        
        <!-- Why RRT Section -->
        <section class="section why-rrt">
            <div class="container">
                <div class="why-grid">
                    <div class="why-content">
                        <span class="section-tag">Why Choose Us</span>
                        <h2>Small Classes.<br>Big Dreams.<br><span class="highlight">Real Results.</span></h2>
                        
                        <p>At Rhythmic Ribbon of Texas, every gymnast receives personalized attention in a supportive environment. Our certified coaches bring decades of experience to help your child thrive.</p>
                        
                        <ul class="feature-list">
                            <li><span class="check">✓</span> USAG Certified Instruction</li>
                            <li><span class="check">✓</span> Small Class Sizes</li>
                            <li><span class="check">✓</span> State-of-the-Art Facility</li>
                            <li><span class="check">✓</span> Competitive & Recreational Tracks</li>
                        </ul>
                        
                        <a href="/contact/" class="btn btn-primary">Book Free Trial</a>
                    </div>
                    
                    <div class="why-visual">
                        <div class="feature-cards">
                            <div class="feature-card">
                                <span class="feature-number">15+</span>
                                <span class="feature-label">Years Experience</span>
                            </div>
                            <div class="feature-card accent">
                                <span class="feature-label">Located in</span>
                                <span class="feature-text">McKinney, TX</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        
        <!-- CTA Section -->
        <section class="cta-section">
            <div class="container">
                <span class="section-tag">Get Started Today</span>
                <h2>Ready to Start the Journey?</h2>
                <p>Book a free trial class and see why families choose Rhythmic Ribbon of Texas.</p>
                
                <a href="/contact/" class="btn btn-primary btn-lg">Schedule Your Trial</a>
            </div>
        </section>
    </main>
    
    <Footer />
</Layout>

<style>
    /* Hero Section - Dark background */
    .hero {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 1fr 1fr;
        align-items: center;
        padding: 120px 5% 4rem;
        background: var(--dark);
        gap: 4rem;
        position: relative;
        overflow: hidden;
    }
    
    .hero::before {
        content: '';
        position: absolute;
        top: 0;
        right: 0;
        width: 50%;
        height: 100%;
        background: linear-gradient(135deg, transparent 0%, rgba(212, 175, 55, 0.03) 100%);
        pointer-events: none;
    }
    
    .hero-content {
        max-width: 600px;
        position: relative;
        z-index: 1;
    }
    
    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(212, 175, 55, 0.1);
        border: 1px solid rgba(212, 175, 55, 0.2);
        color: var(--primary);
        padding: 0.5rem 1rem;
        border-radius: 50px;
        font-size: 0.875rem;
        font-weight: 600;
        margin-bottom: 1.5rem;
    }
    
    .badge-icon {
        width: 8px;
        height: 8px;
        background: var(--primary);
        border-radius: 50%;
        box-shadow: 0 0 10px var(--primary);
    }
    
    .hero h1 {
        font-size: clamp(2.5rem, 5vw, 4rem);
        line-height: 1.1;
        margin-bottom: 1.5rem;
        color: var(--cream);
    }
    
    .hero-text {
        font-size: 1.125rem;
        color: rgba(245, 240, 230, 0.7);
        margin-bottom: 2rem;
        max-width: 500px;
        line-height: 1.7;
    }
    
    .hero-actions {
        display: flex;
        gap: 1rem;
        margin-bottom: 3rem;
        flex-wrap: wrap;
    }
    
    .hero-stats {
        display: flex;
        gap: 2.5rem;
    }
    
    .stat {
        display: flex;
        flex-direction: column;
    }
    
    .stat-number {
        font-family: 'Poppins', sans-serif;
        font-size: 1.75rem;
        font-weight: 800;
        color: var(--primary);
    }
    
    .stat-label {
        font-size: 0.875rem;
        color: rgba(245, 240, 230, 0.6);
    }
    
    .hero-visual {
        display: flex;
        justify-content: center;
        align-items: center;
        position: relative;
    }
    
    .hero-image {
        width: 100%;
        max-width: 500px;
        border-radius: 16px;
        box-shadow: var(--shadow-lg);
        object-fit: cover;
        border: 1px solid rgba(212, 175, 55, 0.2);
    }
    
    /* Programs Section - Dark secondary background */
    .programs {
        background: #0D0D0D;
    }
    
    .program-cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
    }
    
    .program-card {
        background: #1A1A1A;
        border-radius: 16px;
        padding: 2rem;
        border: 1px solid rgba(212, 175, 55, 0.2);
        transition: all 0.3s ease;
        text-decoration: none;
        display: block;
    }
    
    .program-card:hover {
        transform: translateY(-8px);
        border-color: var(--primary);
        box-shadow: var(--shadow-gold);
    }
    
    .card-icon {
        width: 64px;
        height: 64px;
        border-radius: 16px;
        margin-bottom: 1.5rem;
    }
    
    .card-icon.recreational {
        background: linear-gradient(135deg, #D4AF37 0%, #E8C84D 100%);
        box-shadow: 0 4px 15px rgba(212, 175, 55, 0.3);
    }
    
    .card-icon.preteam {
        background: linear-gradient(135deg, #C9A227 0%, #D4AF37 100%);
        box-shadow: 0 4px 15px rgba(201, 162, 39, 0.3);
    }
    
    .card-icon.competitive {
        background: linear-gradient(135deg, #E8C84D 0%, #F0D76A 100%);
        box-shadow: 0 4px 15px rgba(232, 200, 77, 0.3);
    }
    
    .program-card h3 {
        font-size: 1.5rem;
        margin-bottom: 0.75rem;
        color: var(--cream);
    }
    
    .program-card p {
        color: rgba(245, 240, 230, 0.7);
        margin-bottom: 1.5rem;
        line-height: 1.6;
    }
    
    .card-link {
        color: var(--primary);
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        transition: gap 0.3s;
    }
    
    .program-card:hover .card-link {
        gap: 0.5rem;
        color: var(--accent);
    }
    
    /* Why RRT Section - Dark secondary background */
    .why-rrt {
        background: #1A1A1A;
        position: relative;
    }
    
    .why-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
    }
    
    .why-content h2 {
        font-size: clamp(2rem, 4vw, 3rem);
        margin-bottom: 1.5rem;
        color: var(--cream);
    }
    
    .why-content p {
        color: rgba(245, 240, 230, 0.7);
        font-size: 1.125rem;
        margin-bottom: 2rem;
        line-height: 1.7;
    }
    
    .feature-list {
        list-style: none;
        margin-bottom: 2rem;
    }
    
    .feature-list li {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1rem;
        font-size: 1.0625rem;
        color: var(--cream);
    }
    
    .check {
        width: 24px;
        height: 24px;
        background: var(--primary);
        color: var(--dark);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        flex-shrink: 0;
        font-weight: 700;
    }
    
    .feature-cards {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        max-width: 300px;
        margin-left: auto;
    }
    
    .feature-card {
        background: #0D0D0D;
        border-radius: 16px;
        padding: 2rem;
        border: 1px solid rgba(212, 175, 55, 0.2);
        text-align: center;
        transition: all 0.3s ease;
    }
    
    .feature-card:hover {
        border-color: var(--primary);
        box-shadow: var(--shadow-gold);
    }
    
    .feature-card.accent {
        background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
        border-color: transparent;
    }
    
    .feature-card.accent:hover {
        box-shadow: 0 10px 30px rgba(212, 175, 55, 0.4);
    }
    
    .feature-number {
        display: block;
        font-family: 'Poppins', sans-serif;
        font-size: 3rem;
        font-weight: 800;
        color: var(--primary);
    }
    
    .feature-card.accent .feature-number {
        color: var(--dark);
    }
    
    .feature-label {
        display: block;
        font-size: 0.875rem;
        color: rgba(245, 240, 230, 0.6);
        margin-top: 0.25rem;
    }
    
    .feature-card.accent .feature-label {
        color: rgba(13, 13, 13, 0.8);
    }
    
    .feature-text {
        display: block;
        font-family: 'Poppins', sans-serif;
        font-size: 1.5rem;
        font-weight: 700;
        margin-top: 0.25rem;
        color: var(--dark);
    }
    
    /* CTA Section */
    .cta-section {
        background: linear-gradient(135deg, #1A1A1A 0%, #0D0D0D 100%);
        text-align: center;
        padding: 6rem 0;
        position: relative;
        overflow: hidden;
    }
    
    .cta-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--primary), transparent);
    }
    
    .cta-section h2 {
        font-size: clamp(2rem, 4vw, 3rem);
        margin-bottom: 1rem;
        color: var(--primary);
    }
    
    .cta-section p {
        font-size: 1.25rem;
        color: rgba(245, 240, 230, 0.7);
        margin-bottom: 2rem;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
    }
    
    @media (max-width: 1024px) {
        .hero {
            grid-template-columns: 1fr;
            text-align: center;
            padding-top: 100px;
        }
        
        .hero-content {
            max-width: 100%;
        }
        
        .hero-text {
            margin-left: auto;
            margin-right: auto;
        }
        
        .hero-actions {
            justify-content: center;
        }
        
        .hero-stats {
            justify-content: center;
        }
        
        .hero-visual {
            display: none;
        }
        
        .program-cards {
            grid-template-columns: 1fr;
        }
        
        .why-grid {
            grid-template-columns: 1fr;
        }
        
        .feature-cards {
            margin: 0 auto;
        }
    }
    
    @media (max-width: 640px) {
        .hero-actions {
            flex-direction: column;
            align-items: center;
        }
        
        .hero-actions .btn {
            width: 100%;
            max-width: 280px;
        }
    }
</style>