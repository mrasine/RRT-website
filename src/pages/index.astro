---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "Rhythmic Ribbon of Texas | Free Trial Classes McKinney & Frisco";
const description = "Free trial classes in McKinney & Frisco. USAG certified coaches. Ages 5+. Book online today.";
---

<Layout title={title} description={description}>
    <Header />
    
    <main>
        <!-- Hero Section -->
        <section class="hero">
            <div class="hero-content">
                <span class="hero-badge">McKinney & Frisco</span>
                <h1>Free Trial Classes<br><span class="highlight">Available Now</span></h1>
                <p class="hero-text">Ages 5+. No experience needed. Book online in 2 minutes.</p>
                
                <div class="hero-actions">
                    <a href="/contact/" class="btn btn-primary btn-lg">Book Free Trial</a>
                    <a href="tel:7186892469" class="btn btn-outline btn-lg">Call (718) 689-2469</a>
                </div>
                
                <div class="hero-stats">
                    <div class="stat"><span class="stat-number">5+</span><span class="stat-label">Ages</span></div>
                    <div class="stat"><span class="stat-number">USAG</span><span class="stat-label">Certified</span></div>
                    <div class="stat"><span class="stat-number">2</span><span class="stat-label">Locations</span></div>
                </div>
            </div>
            
            <div class="hero-visual">
                <img src="/images/hero-competition.jpg" alt="RRT Competition Team" class="hero-image" />
            </div>
        </section>
        
        <!-- Trial Times -->
        <section class="section trial-times">
            <div class="container">
                <h2 class="section-title">Next Available<br><span class="highlight"> Trial Classes</span></h2>
                
                <div class="trial-grid">
                    <div class="trial-card">
                        <h3>McKinney</h3>
                        <p class="trial-address">4260 Eldorado Pkwy, 2nd Floor</p>
                        <div class="trial-slots">
                            <div class="trial-slot"><span class="day">Wednesday</span><span class="time">6:00 - 7:30 PM</span></div>
                            <div class="trial-slot"><span class="day">Saturday</span><span class="time">12:45 - 2:15 PM</span></div>
                        </div>
                        <a href="/contact/" class="btn btn-primary">Book McKinney</a>
                    </div>
                    
                    <div class="trial-card">
                        <h3>Frisco</h3>
                        <p class="trial-address">7255 Meadow Hill Dr, Field #5</p>
                        <div class="trial-slots">
                            <div class="trial-slot"><span class="day">Saturday</span><span class="time">3:00 - 4:30 PM</span></div>
                        </div>
                        <a href="/contact/" class="btn btn-primary">Book Frisco</a>
                    </div>
                </div>
                
                <p class="trial-note">Trials are free. Ages 5+. No experience required.</p>
            </div>
        </section>
        
        <!-- Programs -->
        <section class="section programs">
            <div class="container">
                <h2 class="section-title" style="color: #F5F0E6;">Programs for Every<br><span class="highlight">Gymnast</span></h2>
                <p class="section-subtitle">From first steps on the mat to competitive excellence.</p>
                
                <div class="program-cards">
                    <a href="/programs/#recreational" class="program-card">
                        <div class="card-icon recreational"></div>
                        <h3>Recreational</h3>
                        <p>Ages 5+. Fun fundamentals for beginners.</p>
                        <span class="card-link">Learn More →</span>
                    </a>
                    
                    <a href="/programs/#preteam" class="program-card">
                        <div class="card-icon preteam"></div>
                        <h3>Pre-Team</h3>
                        <p>Bridge to competitive readiness.</p>
                        <span class="card-link">Learn More →</span>
                    </a>
                    
                    <a href="/programs/#competitive" class="program-card">
                        <div class="card-icon competitive"></div>
                        <h3>Competitive</h3>
                        <p>USAG Levels 3-10 for dedicated athletes.</p>
                        <span class="card-link">Learn More →</span>
                    </a>
                </div>
            </div>
        </section>
        
        <!-- Why RRT -->
        <section class="section why-rrt">
            <div class="container">
                <div class="why-grid">
                    <div class="why-content">
                        <span class="section-tag">Why Choose Us</span>
                        <h2>Expert Coaching in a<br><span class="highlight">Supportive Environment</span></h2>
                        <p>Coach Ella brings decades of experience and USAG certification. We focus on technical accuracy, discipline, and long-term athlete development.</p>
                        
                        <ul class="feature-list">
                            <li><span class="check">✓</span> USAG Certified Instruction</li>
                            <li><span class="check">✓</span> Small Class Sizes</li>
                            <li><span class="check">✓</span> Two Convenient Locations</li>
                            <li><span class="check">✓</span> Free Trial Classes</li>
                        </ul>
                        
                        <a href="/contact/" class="btn btn-primary">Schedule Your Free Trial</a>
                    </div>
                    
                    <div class="why-visual">
                        <div class="feature-cards">
                            <div class="feature-card"><span class="feature-number">15+</span><span class="feature-label">Years Experience</span></div>
                            <div class="feature-card accent"><span class="feature-label">Located in</span><span class="feature-text">McKinney & Frisco</span></div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        
        <!-- CTA -->
        <section class="cta-section">
            <div class="container">
                <span class="section-tag">Get Started Today</span>
                <h2>Ready to Start the Journey?</h2>
                <p>Book a free trial class and discover why families choose Rhythmic Ribbon of Texas.</p>
                <a href="/contact/" class="btn btn-primary btn-lg">Book Free Trial Now</a>
            </div>
        </section>
    </main>
    
    <Footer />
</Layout>

<style>
    .trial-times { background: #1A1A1A; padding: 5rem 0; }
    .trial-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; margin-top: 3rem; }
    .trial-card { background: #2A2A2A; border-radius: 16px; padding: 2rem; border: 1px solid rgba(212, 175, 55, 0.3); text-align: center; }
    .trial-card h3 { color: #D4AF37; font-size: 1.5rem; margin-bottom: 0.5rem; }
    .trial-address { color: #AAAAAA; font-size: 0.9rem; margin-bottom: 1.5rem; }
    .trial-slots { margin-bottom: 1.5rem; }
    .trial-slot { display: flex; justify-content: space-between; padding: 0.75rem; background: #0D0D0D; border-radius: 8px; margin-bottom: 0.5rem; }
    .trial-slot .day { font-weight: 600; color: #F5F0E6; }
    .trial-slot .time { color: #D4AF37; }
    .trial-note { text-align: center; color: #AAAAAA; margin-top: 2rem; font-size: 0.9rem; }
    .section-subtitle { text-align: center; color: rgba(245, 240, 230, 0.7); font-size: 1.1rem; margin-bottom: 3rem; }
</style>
