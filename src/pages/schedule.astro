---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "Schedule | Rhythmic Ribbon of Texas";
const description = "View beginner class schedules for Rhythmic Ribbon of Texas in McKinney and Frisco. Contact us for competitive team and advanced program schedules.";

const beginnerSchedule = [
    { 
        location: "McKinney", 
        address: "4260 Eldorado Parkway, McKinney, TX 75070",
        classes: [
            { day: "Monday", time: "4:00 PM", name: "Beginners (Ages 3-5)", duration: "45 min" },
            { day: "Monday", time: "5:00 PM", name: "Beginners (Ages 6-8)", duration: "60 min" },
            { day: "Wednesday", time: "4:00 PM", name: "Beginners (Ages 3-5)", duration: "45 min" },
            { day: "Saturday", time: "9:00 AM", name: "Beginners (All Ages)", duration: "60 min" }
        ]
    },
    { 
        location: "Frisco", 
        address: "Frisco Location",
        classes: [
            { day: "Tuesday", time: "4:00 PM", name: "Beginners (Ages 6-8)", duration: "60 min" },
            { day: "Thursday", time: "5:15 PM", name: "Beginners (Ages 9-12)", duration: "60 min" },
            { day: "Saturday", time: "10:15 AM", name: "Beginners (All Ages)", duration: "60 min" }
        ]
    }
];

const otherPrograms = [
    "Pre-Team",
    "Competitive Team (Levels 3-10)", 
    "Xcel Program",
    "Ballet",
    "Multi-Sport Flexibility",
    "Private Lessons"
];
---

<Layout title={title} description={description}>
    <Header />
    
    <main>
        <section class="page-header">
            <div class="container">
                <span class="section-tag">Schedule</span>
                <h1>Class<br><span class="highlight">Schedule</span></h1>
                <p class="subtitle">Beginner classes in McKinney and Frisco. Contact us for all other program schedules.</p>
            </div>
        </section>
        
        <!-- Beginner Classes Schedule -->
        <section class="section">
            <div class="container">
                <h2 class="section-title">Beginner<span class="highlight">Classes</span></h2>
                <p class="section-subtitle">Perfect for ages 3+. No experience needed. Free trial class available.</p>
                
                <div class="locations-grid">
                    {beginnerSchedule.map(location => (
                        <div class="location-card">
                            <div class="location-header">
                                <h3>{location.location}</h3>
                                <p class="address">{location.address}</p>
                            </div>
                            
                            <div class="schedule-list">
                                {location.classes.map(cls => (
                                    <div class="schedule-item">
                                        <div class="day-time">
                                            <span class="day">{cls.day}</span>
                                            <span class="time">{cls.time}</span>
                                        </div>
                                        <div class="class-details">
                                            <span class="class-name">{cls.name}</span>
                                            <span class="duration">{cls.duration}</span>
                                        </div>
                                    </div>
                                ))}
                            </div>
                            
                            <a href="/contact/" class="btn btn-primary">Book Free Trial</a>
                        </div>
                    ))}
                </div>
            </div>
        </section>
        
        <!-- Other Programs -->
        <section class="section other-programs">
            <div class="container">
                <h2 class="section-title">Other<span class="highlight">Programs</span></h2>
                <p class="section-subtitle">Contact us for schedule and pricing information for these programs.</p>
                
                <div class="programs-grid">
                    {otherPrograms.map(program => (
                        <div class="program-item">
                            <span class="program-name">{program}</span>
                            <span class="contact-badge">Contact for Schedule</span>
                        </div>
                    ))}
                </div>
                
                <div class="contact-cta">
                    <a href="/contact/" class="btn btn-primary btn-lg">Contact Us for Details</a>
                </div>
            </div>
        </section>
        
        <!-- Pricing Info -->
        <section class="section pricing-info">
            <div class="container">
                <div class="info-card">
                    <h3>Pricing</h3>
                    <p>Pricing varies by program and commitment level. Contact Coach Ella for current rates and family discounts.</p>
                    
                    <ul class="info-list">
                        <li>Free trial class for new students</li>
                        <li>Family discounts available</li>
                        <li>No long-term contracts required</li>
                    </ul>
                    
                    <a href="/contact/" class="btn btn-outline">Get Pricing Info</a>
                </div>
            </div>
        </section>
    </main>
    
    <Footer />
</Layout>

<style>
    .page-header {
        background: linear-gradient(135deg, #0D0D0D 0%, #1A1A1A 100%);
        color: #F5F0E6;
        padding: 160px 0 4rem;
        text-align: center;
    }
    
    .page-header h1 {
        font-size: clamp(2.5rem, 5vw, 3.5rem);
        margin-bottom: 1rem;
        color: #F5F0E6;
    }
    
    .page-header .subtitle {
        font-size: 1.25rem;
        color: rgba(245, 240, 230, 0.8);
        max-width: 600px;
        margin: 0 auto;
    }
    
    .section {
        background: #0D0D0D;
        padding: 5rem 0;
    }
    
    .section-title {
        text-align: center;
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
        color: #F5F0E6;
    }
    
    .section-title .highlight {
        color: #D4AF37;
    }
    
    .section-subtitle {
        text-align: center;
        color: rgba(245, 240, 230, 0.7);
        margin-bottom: 3rem;
        font-size: 1.125rem;
    }
    
    .locations-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
    }
    
    .location-card {
        background: #1A1A1A;
        border-radius: 16px;
        padding: 2rem;
        border: 1px solid #333;
    }
    
    .location-header {
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid #D4AF37;
    }
    
    .location-header h3 {
        font-size: 1.5rem;
        color: #D4AF37;
        margin-bottom: 0.5rem;
    }
    
    .address {
        color: rgba(245, 240, 230, 0.6);
        font-size: 0.9375rem;
    }
    
    .schedule-list {
        margin-bottom: 1.5rem;
    }
    
    .schedule-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 0;
        border-bottom: 1px solid #333;
    }
    
    .schedule-item:last-child {
        border-bottom: none;
    }
    
    .day-time {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }
    
    .day {
        font-weight: 700;
        color: #F5F0E6;
        font-size: 0.9375rem;
    }
    
    .time {
        color: #D4AF37;
        font-weight: 600;
    }
    
    .class-details {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.25rem;
    }
    
    .class-name {
        color: #F5F0E6;
        font-size: 0.9375rem;
    }
    
    .duration {
        font-size: 0.8125rem;
        color: rgba(245, 240, 230, 0.6);
        background: #2a2a2a;
        padding: 0.25rem 0.5rem;
        border-radius: 4px;
    }
    
    .other-programs {
        background: #1A1A1A;
    }
    
    .programs-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-bottom: 2rem;
    }
    
    .program-item {
        background: #0D0D0D;
        border-radius: 12px;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        border: 1px solid #333;
    }
    
    .program-name {
        font-weight: 600;
        color: #F5F0E6;
        font-size: 1.125rem;
    }
    
    .contact-badge {
        font-size: 0.8125rem;
        color: #D4AF37;
        font-weight: 500;
    }
    
    .contact-cta {
        text-align: center;
    }
    
    .pricing-info {
        background: #0D0D0D;
    }
    
    .info-card {
        background: #1A1A1A;
        border-radius: 16px;
        padding: 3rem;
        max-width: 700px;
        margin: 0 auto;
        text-align: center;
        border: 1px solid #333;
    }
    
    .info-card h3 {
        font-size: 1.75rem;
        color: #D4AF37;
        margin-bottom: 1rem;
    }
    
    .info-card p {
        color: rgba(245, 240, 230, 0.7);
        margin-bottom: 1.5rem;
        font-size: 1.0625rem;
    }
    
    .info-list {
        list-style: none;
        margin-bottom: 2rem;
    }
    
    .info-list li {
        color: #F5F0E6;
        padding: 0.5rem 0;
        position: relative;
        padding-left: 1.5rem;
    }
    
    .info-list li::before {
        content: '✓';
        position: absolute;
        left: 0;
        color: #D4AF37;
        font-weight: 700;
    }
    
    @media (max-width: 1024px) {
        .locations-grid {
            grid-template-columns: 1fr;
        }
        
        .programs-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    
    @media (max-width: 640px) {
        .programs-grid {
            grid-template-columns: 1fr;
        }
        
        .info-card {
            padding: 2rem;
        }
    }
</style>