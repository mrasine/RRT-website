---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "Schedule & Pricing | Rhythmic Ribbon of Texas";
const description = "View class schedules and pricing for Rhythmic Ribbon of Texas. Recreational, competitive, and pre-team programs. Free trial class available.";

const schedule = [
    { day: "Monday", classes: [
        { time: "4:00 PM", name: "Recreational (Ages 3-5)", duration: "45 min" },
        { time: "5:00 PM", name: "Recreational (Ages 6-8)", duration: "60 min" },
        { time: "6:15 PM", name: "Pre-Team", duration: "90 min" },
        { time: "7:45 PM", name: "Competitive Team", duration: "2 hrs" }
    ]},
    { day: "Tuesday", classes: [
        { time: "4:00 PM", name: "Ballet (Ages 8-12)", duration: "60 min" },
        { time: "5:15 PM", name: "Recreational (Ages 9-12)", duration: "60 min" },
        { time: "6:30 PM", name: "Xcel Program", duration: "90 min" }
    ]},
    { day: "Wednesday", classes: [
        { time: "4:00 PM", name: "Recreational (Ages 3-5)", duration: "45 min" },
        { time: "5:00 PM", name: "Multi-Sport Flexibility", duration: "60 min" },
        { time: "6:15 PM", name: "Pre-Team", duration: "90 min" },
        { time: "7:45 PM", name: "Competitive Team", duration: "2 hrs" }
    ]},
    { day: "Thursday", classes: [
        { time: "4:00 PM", name: "Recreational (Ages 6-8)", duration: "60 min" },
        { time: "5:15 PM", name: "Ballet (Ages 8-12)", duration: "60 min" },
        { time: "6:30 PM", name: "Xcel Program", duration: "90 min" }
    ]},
    { day: "Friday", classes: [
        { time: "4:00 PM", name: "Recreational (Ages 5-7)", duration: "60 min" },
        { time: "5:15 PM", name: "Open Gym", duration: "90 min" }
    ]},
    { day: "Saturday", classes: [
        { time: "9:00 AM", name: "Recreational (All Ages)", duration: "60 min" },
        { time: "10:15 AM", name: "Pre-Team", duration: "90 min" },
        { time: "12:00 PM", name: "Competitive Team", duration: "2 hrs" },
        { time: "2:15 PM", name: "Private Lessons", duration: "varies" }
    ]}
];

const pricing = [
    { program: "Recreational", price: "$85", period: "month", note: "1 class per week" },
    { program: "Pre-Team", price: "$165", period: "month", note: "2 classes per week" },
    { program: "Xcel Program", price: "$195", period: "month", note: "2-3 classes per week" },
    { program: "Competitive Team", price: "$285", period: "month", note: "Unlimited training" },
    { program: "Ballet", price: "$65", period: "month", note: "Add-on to any program" },
    { program: "Private Lessons", price: "$75", period: "hour", note: "One-on-one coaching" }
];
---

<Layout title={title} description={description}>
    <Header />
    
    <main>
        <section class="page-header">
            <div class="container">
                <span class="section-tag">Schedule</span>
                <h1>Classes &<br><span class="highlight">Pricing</span></h1>
                <p class="subtitle">Transparent pricing. Flexible scheduling. Free trial class for new students.</p>
            </div>
        </section>
        
        <section class="section">
            <div class="container">
                <h2 class="section-title">Weekly<span class="highlight">Schedule</span></h2>
                
                <div class="schedule-grid">
                    {schedule.map(day => (
                        <div class="day-card">
                            <h3>{day.day}</h3>
                            <div class="classes">
                                {day.classes.map(cls => (
                                    <div class="class-item">
                                        <span class="time">{cls.time}</span>
                                        <div class="class-info">
                                            <span class="name">{cls.name}</span>
                                            <span class="duration">{cls.duration}</span>
                                        </div>
                                    </div>
                                ))}
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </section>
        
        <section class="section pricing-section">
            <div class="container">
                <h2 class="section-title">Monthly<span class="highlight">Pricing</span></h2>
                
                <div class="pricing-grid">
                    {pricing.map(item => (
                        <div class="pricing-card">
                            <div class="pricing-header">
                                <h3>{item.program}</h3>
                                <div class="price">
                                    <span class="amount">{item.price}</span>
                                    <span class="period">/{item.period}</span>
                                </div>
                            </div>
                            <p class="note">{item.note}</p>
                            
                            <a href="/contact/" class="btn btn-outline">Get Started</a>
                        </div>
                    ))}
                </div>
                
                <div class="pricing-notes">
                    <p><strong>Additional Fees:</strong> Annual registration fee of $50 per student. Competition fees apply for team members. Family discounts available for multiple children.</p>
                </div>
            </div>
        </section>
        
        <section class="cta-section">
            <div class="container">
                <div class="trial-card">
                    <h2>Free Trial Class</h2>
                    <p>Not sure which program is right? Schedule a free trial class and let our coaches assess the best fit for your child.</p>
                    
                    <a href="/contact/" class="btn btn-primary btn-lg">Book Your Free Trial</a>
                </div>
            </div>
        </section>
    </main>
    
    <Footer />
</Layout>

<style>
    .page-header {
        background: linear-gradient(135deg, var(--dark) 0%, #1a252f 100%);
        color: white;
        padding: 160px 0 4rem;
        text-align: center;
    }
    
    .page-header h1 {
        font-size: clamp(2.5rem, 5vw, 3.5rem);
        margin-bottom: 1rem;
    }
    
    .page-header .subtitle {
        font-size: 1.25rem;
        color: rgba(255,255,255,0.8);
        max-width: 600px;
        margin: 0 auto;
    }
    
    .schedule-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
    }
    
    .day-card {
        background: white;
        border-radius: 16px;
        padding: 1.5rem;
        box-shadow: var(--shadow);
    }
    
    .day-card h3 {
        font-size: 1.25rem;
        color: var(--primary);
        margin-bottom: 1rem;
        padding-bottom: 0.75rem;
        border-bottom: 2px solid #f0f0f0;
    }
    
    .class-item {
        padding: 0.75rem 0;
        border-bottom: 1px solid #f5f5f5;
    }
    
    .class-item:last-child {
        border-bottom: none;
    }
    
    .time {
        display: block;
        font-weight: 700;
        color: var(--dark);
        font-size: 0.9375rem;
    }
    
    .class-info {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 0.25rem;
    }
    
    .name {
        font-size: 0.9375rem;
        color: var(--dark);
    }
    
    .duration {
        font-size: 0.8125rem;
        color: var(--gray);
        background: #f5f5f5;
        padding: 0.25rem 0.5rem;
        border-radius: 4px;
    }
    
    .pricing-section {
        background: var(--light);
    }
    
    .pricing-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
    }
    
    .pricing-card {
        background: white;
        border-radius: 16px;
        padding: 2rem;
        box-shadow: var(--shadow);
        text-align: center;
        transition: transform 0.3s;
    }
    
    .pricing-card:hover {
        transform: translateY(-4px);
    }
    
    .pricing-header {
        margin-bottom: 1rem;
    }
    
    .pricing-header h3 {
        font-size: 1.25rem;
        color: var(--dark);
        margin-bottom: 0.75rem;
    }
    
    .price {
        display: flex;
        align-items: baseline;
        justify-content: center;
        gap: 0.25rem;
    }
    
    .amount {
        font-family: 'Poppins', sans-serif;
        font-size: 2.5rem;
        font-weight: 800;
        color: var(--primary);
    }
    
    .period {
        color: var(--gray);
        font-size: 1rem;
    }
    
    .note {
        color: var(--gray);
        font-size: 0.9375rem;
        margin-bottom: 1.5rem;
    }
    
    .pricing-notes {
        background: white;
        padding: 1.5rem 2rem;
        border-radius: 12px;
        margin-top: 2rem;
        text-align: center;
        color: var(--gray);
    }
    
    .cta-section {
        padding: 4rem 0;
    }
    
    .trial-card {
        background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
        color: white;
        padding: 4rem;
        border-radius: 24px;
        text-align: center;
    }
    
    .trial-card h2 {
        font-size: 2.5rem;
        margin-bottom: 1rem;
    }
    
    .trial-card p {
        font-size: 1.25rem;
        opacity: 0.95;
        max-width: 600px;
        margin: 0 auto 2rem;
    }
    
    @media (max-width: 1024px) {
        .schedule-grid {
            grid-template-columns: repeat(2, 1fr);
        }
        
        .pricing-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    
    @media (max-width: 640px) {
        .schedule-grid,
        .pricing-grid {
            grid-template-columns: 1fr;
        }
        
        .trial-card {
            padding: 2rem;
        }
    }
</style>
